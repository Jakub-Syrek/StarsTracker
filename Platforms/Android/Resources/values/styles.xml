<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Override MAUI's main theme to use the app's dark background,
         preventing the white flash before the first page renders. -->
    <style name="Maui.MainTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/appBackground</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
</resources>
