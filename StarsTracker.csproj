<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net10.0-android</TargetFrameworks>
		<OutputType>Exe</OutputType>
		<RootNamespace>StarsTracker</RootNamespace>
		<UseMaui>true</UseMaui>
		<SingleProject>true</SingleProject>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<!-- MauiXamlInflator=SourceGen removed: using default runtime inflation -->

		<!-- App metadata -->
		<ApplicationTitle>StarsTracker</ApplicationTitle>
		<ApplicationId>com.jakubsyrek.starstracker</ApplicationId>
		<ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
		<ApplicationVersion>1</ApplicationVersion>

		<SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">21.0</SupportedOSPlatformVersion>

		<!-- Embed assemblies into APK so adb install works without IDE Fast Deployment -->
		<EmbedAssembliesIntoApk>true</EmbedAssembliesIntoApk>
	</PropertyGroup>

	<ItemGroup>
		<!-- App Icon -->
		<MauiIcon Include="Resources\AppIcon\appicon.svg" ForegroundFile="Resources\AppIcon\appiconfg.svg" Color="#0A0A1A" />

		<!-- Splash Screen -->
		<MauiSplashScreen Include="Resources\Splash\splash.svg" Color="#0A0A1A" BaseSize="128,128" />

		<!-- Images -->
		<MauiImage Include="Resources\Images\*" />

		<!-- Custom Fonts -->
		<MauiFont Include="Resources\Fonts\*" />

		<!-- Raw Assets -->
		<MauiAsset Include="Resources\Raw\**" LogicalName="%(RecursiveDir)%(Filename)%(Extension)" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="StarsTracker.Core\StarsTracker.Core.csproj" />
	</ItemGroup>

	<!-- Don't double-compile the Core sub-project's files into the main app -->
	<ItemGroup>
		<Compile Remove="StarsTracker.Core\**" />
		<None Remove="StarsTracker.Core\**" />
		<EmbeddedResource Remove="StarsTracker.Core\**" />
		<MauiXaml Remove="StarsTracker.Core\**" />
		<MauiCss Remove="StarsTracker.Core\**" />
		<Compile Remove="StarsTracker.Tests\**" />
		<None Remove="StarsTracker.Tests\**" />
		<EmbeddedResource Remove="StarsTracker.Tests\**" />
		<MauiXaml Remove="StarsTracker.Tests\**" />
		<MauiCss Remove="StarsTracker.Tests\**" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Maui.Controls" Version="10.0.60" />
		<PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="10.0.0" />
		<PackageReference Include="CommunityToolkit.Maui" Version="14.1.1" />
		<PackageReference Include="CommunityToolkit.Maui.Camera" Version="6.0.1" />
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
	</ItemGroup>

</Project>
